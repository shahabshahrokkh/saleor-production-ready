# Copy this file to .env and fill in ALL values before deploying

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=strong_random_password
DATABASE_URL=postgres://saleor:strong_random_password@db/saleor

# ─── Cache / Celery ──────────────────────────────────────────────────────────
CACHE_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ─── Django ──────────────────────────────────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your_long_random_secret_key_here

DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_CLIENT_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_GRAPHQL_ORIGINS=https://yourdomain.com,https://dashboard.yourdomain.com

# Public URL of the API
PUBLIC_URL=https://api.yourdomain.com

# RSA key for JWT (required when DEBUG=False)
# Generate: openssl genrsa 2048 | awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}'
RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_URL=smtp://user:password@smtp.example.com:587/?tls=True
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ─── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_URL=https://dashboard.yourdomain.com/

# ─── Security ────────────────────────────────────────────────────────────────
HTTP_IP_FILTER_ALLOW_LOOPBACK_IPS=True

# ─── Storefront ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SALEOR_API_URL=https://api.yourdomain.com/graphql/
NEXT_PUBLIC_STOREFRONT_URL=https://yourdomain.com
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel

# Webhook secret - set same value in Saleor Dashboard → Configuration → Webhooks
SALEOR_WEBHOOK_SECRET=random_string_min_32_characters_long
# Secret for manual cache invalidation via /api/revalidate endpoint
REVALIDATE_SECRET=another_random_string_min_32_characters
